#!/bin/bash

#SBATCH --job-name=EnvDownGptOss
#SBATCH --partition=rome
#SBATCH --time=01:30:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH --output=slurm_logs/slurm_%A.out

set -euo pipefail

module purge
module load 2025
module load Python/3.13.5-GCCcore-14.3.0
module load CMake/4.0.3-GCCcore-14.3.0

# Cache model weights on /scratch-shared (200 GiB home quota is too small).
# See docs/docs.hf_cache_on_scratch_shared.md for rationale.
export HF_HOME=/scratch-shared/dlindberg/hf_cache
export HF_HUB_CACHE=$HF_HOME/hub
mkdir -p "$HF_HUB_CACHE"

cd "$HOME/Projects/asp-arc-gpt-oss-nvarc"
mkdir -p slurm_logs outputs

VENV=.venv
REPO_ID="openai/gpt-oss-120b"

echo "=== [1/4] Create venv at $VENV ==="
if [ ! -d "$VENV" ]; then
    python3 -m venv "$VENV"
fi
source "$VENV/bin/activate"
python3 -m pip install --upgrade pip

echo ""
echo "=== [2/4] Install vLLM + huggingface_hub ==="
pip install --no-cache-dir -r src/requirements_vllm.txt

echo ""
echo "Installed vLLM version:"
python3 -c "import vllm; print(vllm.__version__)"

echo ""
echo "=== [3/4] Install Clingo + supporting deps ==="
pip install setuptools wheel scikit-build
export CMAKE_ARGS="-DCMAKE_POLICY_VERSION_MINIMUM=3.5"
pip install --no-deps --no-build-isolation -r src/requirements_clingo_etal.txt

echo ""
echo "=== [4/4] Pre-download $REPO_ID safetensors ==="
python3 - <<PY
from huggingface_hub import snapshot_download
path = snapshot_download(
    repo_id="$REPO_ID",
    allow_patterns=["*.safetensors", "*.json", "*.txt", "tokenizer*", "*.py", "*.jinja"],
)
print(f"Downloaded to: {path}")
PY

echo ""
echo "[SLURM] Exiting"
