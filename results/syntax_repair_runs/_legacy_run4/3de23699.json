  "initial_program": "% ----------------------------------------------------------------------\n% 1. Grid dimensions and helpers\n% ----------------------------------------------------------------------\nn_rows(Nr) :- N = #count{ R : input(R, _, _) }.\nn_cols(Nc) :- N = #count{ C : input(_, C, _) }.\n\nrow(R) :- R >= 0, R < Nr.\ncol(C) :- C >= 0, C < Nc.\n\noutput_cell(R,C) :- row(R), col(C).\n\n% ----------------------------------------------------------------------\n% 2. Find the maximal nonzero colour\n% ----------------------------------------------------------------------\nmaxc(K) :- K = #max{ Color : color(Color), Color != 0 }.\n\n% ----------------------------------------------------------------------\n% 3. Cells that contain the maximal colour\n% ----------------------------------------------------------------------\nmaxcRow(R) :- input(R, _, V), V = maxc.\nmaxcCol(C) :- input(_, C, V), V = maxc.\n\n% ----------------------------------------------------------------------\n% 4. Bounding rectangle for the maximal colour\n% ----------------------------------------------------------------------\nrStart0 :- rStart0 = #min{ R : maxcRow(R) }.\nrEnd0   :- rEnd0   = #max{ R : maxcRow(R) } \\ 2.\ncStart0 :- cStart0 = #min{ C : maxcCol(C) }.\ncEnd0   :- cEnd0   = #max{ C : maxcCol(C) } \\ 2.\n\n% ----------------------------------------------------------------------\n% 5. Inrange predicate (the rectangular area where we may place maxc)\n% ----------------------------------------------------------------------\nin_range(R,C) :- row(R), col(C),\n                le(R, rEnd0), ge(R, rStart0),\n                le(C, cEnd0), ge(C, cStart0).\n\n% ----------------------------------------------------------------------\n% 6. Three corner cells that must stay zero\n% ----------------------------------------------------------------------\ncorner(R,C) :- eq(R, rStart0), eq(C, cStart0).\ncorner(R,C) :- eq(R, rStart0), eq(C, cEnd0).\ncorner(R,C) :- eq(R, rEnd0), eq(C, cStart0).\n\n% ----------------------------------------------------------------------\n% 6a. Cells that should receive the maximal colour\n%      either on a maximalrow (and not a corner)\n%      or on a maximalcolumn (and not a corner)\n% ----------------------------------------------------------------------\ntargetCell1(R,C) :- maxcRow(R), in_range(R,C), not corner(R,C).\ntargetCell2(R,C) :- maxcCol(C), in_range(R,C), not corner(R,C).\n\n% ----------------------------------------------------------------------\n% 7. Cells that must be zero (neither targetCell1 nor targetCell2)\n% ----------------------------------------------------------------------\nnotTargetCell(R,C) :- not targetCell1(R,C), not targetCell2(R,C).\n\n% ----------------------------------------------------------------------\n% 8. Exactly one colour per output cell\n% ----------------------------------------------------------------------\n1 { output(R,C,Color) : color(Color) } 1 :- output_cell(R,C).\n\n% ----------------------------------------------------------------------\n% 9. Enforce the required colour\n% ----------------------------------------------------------------------\n%    maxc on cells that belong to targetCell1 or targetCell2\n:- output(R,C,Color), targetCell1(R,C), neq(Color, maxc).\n:- output(R,C,Color), targetCell2(R,C), neq(Color, maxc).\n\n%    zero on all other cells\n:- output(R,C,Color), notTargetCell(R,C), neq(Color, 0).\n\n#show output/3.",
