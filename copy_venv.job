#!/bin/bash

#SBATCH --job-name=CopyVenv
#SBATCH --partition=rome
#SBATCH --time=00:30:00
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --output=outputs/slurm_copy_venv_%A.out

mkdir -p outputs

echo "[SLURM] Copying .venv from asp-gen-refinements to asp-arc..."
cp -r /home/dlindberg/Projects/asp-gen-refinements/.venv /home/dlindberg/Projects/asp-arc/.venv
echo "[SLURM] Done. Verifying..."
ls /home/dlindberg/Projects/asp-arc/.venv/
echo "[SLURM] Copy complete."
